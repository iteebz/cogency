#!/usr/bin/env bash
set -e

commit_msg_file="$1"
subject=$(head -1 "$commit_msg_file")

if echo "$subject" | grep -qE '^Merge '; then exit 0; fi

if ! echo "$subject" | grep -qE '^(feat|fix|docs|chore|test|refactor|style)(\([^)]+\))?: .+$'; then
    echo "BLOCKED — commit message must match: tag(scope): verb object" >&2
    echo "  tags: feat fix docs chore test refactor style" >&2
    echo "  got:  $subject" >&2
    exit 1
fi

if echo "$subject" | grep -qP '[\x{2014}\x{2013}]' 2>/dev/null || echo "$subject" | grep -q '[—–]'; then
    echo "BLOCKED — no em-dashes or en-dashes in commit messages" >&2
    echo "  got:  $subject" >&2
    exit 1
fi

if echo "$subject" | grep -qE '\.$'; then
    echo "BLOCKED — no trailing period" >&2
    echo "  got:  $subject" >&2
    exit 1
fi

if echo "$subject" | grep -qE ','; then
    echo "BLOCKED — comma means split the commit" >&2
    echo "  got:  $subject" >&2
    exit 1
fi

len=${#subject}
if [ "$len" -gt 72 ]; then
    echo "BLOCKED — subject too long ($len chars, max 72)" >&2
    echo "  got:  $subject" >&2
    exit 1
fi
